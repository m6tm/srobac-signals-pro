---
import MainLayout from '../layouts/MainLayout.astro';
import PairCard from '../../components/pairs/PairCard.svelte';
import ActiveSignals from '../../components/signals/ActiveSignals.svelte';
import { PAIR_CONFIGS } from '../../lib/strategy/types';

const pairs = Object.values(PAIR_CONFIGS);
---

<MainLayout>
  <div class="p-4 lg:p-6 space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold">Dashboard SROBAC</h1>
        <p class="text-sm text-text-secondary mt-1">Surveillance des 8 paires JPY en temps réel</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2 px-3 py-2 rounded-md bg-bg-secondary border border-border">
          <div class="w-2 h-2 rounded-full bg-accent-long animate-pulse"></div>
          <span class="text-sm font-medium">Système actif</span>
        </div>
      </div>
    </div>

    <!-- Stats cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="card card-hover">
        <p class="text-xs text-text-secondary uppercase tracking-wider">Signaux ce mois</p>
        <p class="text-2xl font-bold font-mono-price mt-2">0</p>
      </div>
      <div class="card card-hover">
        <p class="text-xs text-text-secondary uppercase tracking-wider">Win Rate</p>
        <p class="text-2xl font-bold font-mono-price mt-2 text-accent-long">--%</p>
      </div>
      <div class="card card-hover">
        <p class="text-xs text-text-secondary uppercase tracking-wider">Profit Factor</p>
        <p class="text-2xl font-bold font-mono-price mt-2 text-accent-info">--</p>
      </div>
      <div class="card card-hover">
        <p class="text-xs text-text-secondary uppercase tracking-wider">Drawdown Max</p>
        <p class="text-2xl font-bold font-mono-price mt-2 text-accent-short">--%</p>
      </div>
    </div>

    <!-- Pairs grid -->
    <div>
      <h2 class="text-lg font-semibold mb-4">Paires surveillées</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        {pairs.map((pair) => (
          <PairCard pair={pair} client:load />
        ))}
      </div>
    </div>

    <!-- Active signals -->
    <div>
      <h2 class="text-lg font-semibold mb-4">Signaux actifs</h2>
      <ActiveSignals signals={[]} client:load />
    </div>
  </div>
</MainLayout>
